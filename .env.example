# PaperVision Environment Variables Configuration

# Gemini API Key (Required for extraction, get from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model to use (e.g. gemini-2.5-flash, gemini-1.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Noise Filtering Heuristics Thresholds
# Minimum dimensions in pixels for a raster image to be considered a figure
MIN_WIDTH=50
MIN_HEIGHT=50
MIN_AREA=2500

# Exclusion zone percentages (e.g., ignore images located strictly in top/bottom X% of the page)
TOP_MARGIN_EXCLUSION_PCT=10.0
BOTTOM_MARGIN_EXCLUSION_PCT=10.0

# Aspect ratio limit: ignore images that are extremely thin or wide (e.g., horizontal/vertical bars)
# Aspect ratio is calculated as max(width/height, height/width)
MAX_ASPECT_RATIO=8.0

# Document-wide deduplication: ignore image hashes appearing on more than this many pages
MAX_HASH_OCCURRENCES=2

# Upload storage directory for temporary file processing
UPLOAD_DIR=storage/uploads
